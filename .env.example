# ===========================================
# MedLive AI - Environment Configuration
# ===========================================

# GoogleWebRTC / Gemini Live API (https://aistudio.google.com)
GOOGLE_WEBRTC_URL=wss://generativelanguage.googleapis.com
GOOGLE_WEBRTC_API_KEY=your_google_webrtc_api_key
GOOGLE_WEBRTC_API_SECRET=your_google_webrtc_api_secret

# Google Gemini API (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key

# Anam Avatar (https://lab.anam.ai/api-keys)
ANAM_API_KEY=your_anam_api_key

# Google Sheets CRM (create a sheet and get the ID from URL)
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_NAME=MedLive AI - Patient Cases

# Agent Configuration
AGENT_NAME=MedLive-AI
