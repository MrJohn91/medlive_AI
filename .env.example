# ===========================================
# MedLive AI - Environment Configuration
# ===========================================

# LiveKit Cloud (https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Google Gemini API (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key

# Anam Avatar (https://lab.anam.ai/api-keys)
ANAM_API_KEY=your_anam_api_key

# Google Sheets CRM (create a sheet and get the ID from URL)
GOOGLE_SHEETS_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_FILE=path_to_service_account.json

# Agent Configuration
AGENT_NAME=MedLive-AI
