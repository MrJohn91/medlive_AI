# ===========================================
# MedLive AI - Environment Configuration
# ===========================================

# GCP Project Configuration
GOOGLE_CLOUD_PROJECT=gemini-agent-challenge
GOOGLE_CLOUD_LOCATION=europe-west1

# Gemini Live API (Native WebRTC Transport)
# Official Endpoint: wss://generativelanguage.googleapis.com
GOOGLE_WEBRTC_URL=wss://generativelanguage.googleapis.com
GOOGLE_WEBRTC_API_KEY=your_google_ai_gateway_key
GOOGLE_WEBRTC_API_SECRET=your_google_ai_gateway_secret

# Google Gemini API Key (Standard SDK)
GOOGLE_API_KEY=your_gemini_api_key

# Anam Avatar API (https://lab.anam.ai)
ANAM_API_KEY=your_anam_api_key

# Google Sheets CRM
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_NAME=Sheet1

# Google Calendar Configuration
OFFICE_LOCATION="MedLive Clinic, Berlin, Germany"

# Agent Dispatch Configuration
AGENT_NAME=MedLive-AI
